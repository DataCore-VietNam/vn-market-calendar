{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":timezone(Asia/Ho_Chi_Minh)",
    "schedule:weekly",
    "group:allNonMajor",
    ":automergeMinor",
    ":automergePatch",
    ":automergeBranch",
    "security:openssf-scorecard"
  ],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "vulnerabilityAlerts": {
    "labels": ["security"]
  },
  "osvVulnerabilityAlerts": true,
  "configMigration": true,
  "ignorePaths": ["**/node_modules/**", "**/.venv/**", "**/dist/**"]
}
